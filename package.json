{
  "name": "unplugin-stylex",
  "version": "0.6.2",
  "packageManager": "pnpm@9.12.2",
  "description": "Unplugin for stylex",
  "repository": "https://github.com/eryue0220/unplugin-stylex",
  "keywords": [
    "unplugin",
    "stylex",
    "stylex-plugin",
    "farm",
    "esbuild",
    "rolldown",
    "rollup",
    "rspack",
    "svelte",
    "vite"
  ],
  "author": "eryue0220<eryue0220@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./astro": {
      "types": "./dist/astro.d.ts",
      "require": "./dist/astro.cjs",
      "import": "./dist/astro.js"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "require": "./dist/esbuild.cjs",
      "import": "./dist/esbuild.js"
    },
    "./farm": {
      "types": "./dist/farm.d.ts",
      "require": "./dist/farm.cjs",
      "import": "./dist/farm.js"
    },
    "./rolldown": {
      "types": "./dist/rolldown.d.ts",
      "require": "./dist/rolldown.cjs",
      "import": "./dist/rolldown.js"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "require": "./dist/rollup.cjs",
      "import": "./dist/rollup.js"
    },
    "./rspack": {
      "types": "./dist/rspack.d.ts",
      "require": "./dist/rspack.cjs",
      "import": "./dist/rspack.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "require": "./dist/vite.cjs",
      "import": "./dist/vite.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "require": "./dist/webpack.cjs",
      "import": "./dist/webpack.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./*": "./*"
  },
  "scripts": {
    "dev": "tsup src/*ts --watch src",
    "build": "pnpm run build:js && pnpm run build:types",
    "build:js": "tsup src/*.ts --format cjs,esm --splitting --clean",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly --noCheck",
    "test": "vitest",
    "test:update": "vitest -u",
    "test:cov": "vitest --coverage",
    "lint": "pnpm biome lint",
    "check": "pnpm biome check .",
    "format": "pnpm biome format .",
    "format:fix": "pnpm biome format --write .",
    "ci": "pnpm run lint && pnpm run check && pnpm run build",
    "turbo:build": "turbo run build",
    "turbo:test": "turbo run test",
    "turbo:lint": "turbo run lint",
    "turbo:check": "turbo run check",
    "turbo:dev": "turbo run dev",
    "jsr": "pnpm dlx jsr publish",
    "sync:jsr-version": "node scripts/sync-jsr-version.mjs",
    "changeset": "pnpm dlx @changesets/cli add",
    "changeset:version": "pnpm dlx @changesets/cli version && pnpm run sync:jsr-version && pnpm install",
    "changeset:release": "pnpm run build && pnpm dlx @changesets/cli publish"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "peerDependencies": {
    "@stylexjs/stylex": "0.x"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-syntax-flow": "^7.28.6",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@babel/plugin-syntax-typescript": "^7.28.6",
    "@rollup/pluginutils": "^5.1.4",
    "@stylexjs/babel-plugin": "^0.18.2",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.0.15",
    "babel-plugin-syntax-hermes-parser": "^0.34.0",
    "jsr": "^0.14.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.0.15"
  }
}
