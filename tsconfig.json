{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "dist",
    "outDir": "./dist",
    "lib": ["ESNext"],
    "moduleResolution": "bundler",
    "preserveSymlinks": true,
    "module": "esnext",
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
